{
  "name": "painel-udiaas",
  "version": "1.0.0",
  "description": "Painel de gerenciamento de servidor - Clean & Optimized",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "multer": "^1.4.5-lts.1",
    "dockerode": "^4.0.2",
    "systeminformation": "^5.21.7",
    "fs-extra": "^11.2.0",
    "archiver": "^6.0.1",
    "unzipper": "^0.10.14",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5"
  }
}
